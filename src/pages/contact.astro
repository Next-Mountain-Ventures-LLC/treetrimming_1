---
import TreeLayout from "@/layouts/TreeLayout.astro";
---

<TreeLayout
  title="Contact Us | Hodge Boys Tree Service | Free Estimate"
  description="Get a free tree service estimate in Forney, Crandall, Kemp and DFW Texas. Call 469-437-2740 or fill out our online form. Licensed & insured. Fast response."
>

<style is:global>
  /* PAGE HERO */
  .page-hero {
    position: relative;
    min-height: 380px;
    display: flex;
    align-items: center;
    background: url('https://images.pexels.com/photos/34674271/pexels-photo-34674271.jpeg?auto=compress&cs=tinysrgb&w=1920') center 35% / cover no-repeat;
  }
  .page-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(10,30,15,0.88) 0%, rgba(10,30,15,0.65) 100%);
  }
  .page-hero-content {
    position: relative;
    z-index: 2;
    padding: 80px 0;
  }
  .page-hero h1 { font-size: clamp(32px, 5vw, 60px); font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 16px; }
  .page-hero h1 span { color: #f59e0b; }
  .page-hero p { font-size: 18px; color: rgba(255,255,255,0.8); max-width: 560px; line-height: 1.6; }
  .breadcrumb { display: flex; gap: 8px; align-items: center; margin-bottom: 16px; }
  .breadcrumb a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 13px; }
  .breadcrumb a:hover { color: #f59e0b; }
  .breadcrumb span { color: rgba(255,255,255,0.4); font-size: 13px; }
  .breadcrumb .current { color: #f59e0b; font-size: 13px; font-weight: 600; }

  /* CONTACT SECTION */
  .contact-section { padding: 80px 0; }
  .contact-split {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: start;
  }

  /* FORM */
  .form-card {
    background: #fff;
    border-radius: 16px;
    padding: 48px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.10);
  }
  .form-card h2 { font-size: 26px; font-weight: 800; color: #1a4d2e; margin-bottom: 6px; }
  .form-card .form-sub { font-size: 14px; color: #666; margin-bottom: 32px; }
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .form-group { margin-bottom: 20px; }
  .form-group.full { grid-column: span 2; }
  .form-group label {
    display: block;
    font-size: 13px;
    font-weight: 600;
    color: #333;
    margin-bottom: 6px;
  }
  .form-group label span { color: #ef4444; }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid #e0e0e0;
    border-radius: 8px;
    font-size: 14px;
    font-family: 'Poppins', sans-serif;
    color: #333;
    background: #fff;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    appearance: none;
    -webkit-appearance: none;
  }
  .form-group select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%23666' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 12px center;
    background-size: 16px;
    padding-right: 36px;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: #1a4d2e;
    box-shadow: 0 0 0 3px rgba(26,77,46,0.1);
  }
  .form-group textarea { min-height: 130px; resize: vertical; }
  .form-submit {
    width: 100%;
    padding: 16px;
    background: #f59e0b;
    color: #1a1a1a;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .form-submit:hover { background: #d97706; transform: translateY(-1px); }
  .form-disclaimer { font-size: 11px; color: #999; text-align: center; margin-top: 12px; line-height: 1.5; }

  /* SUCCESS MESSAGE */
  .form-success {
    display: none;
    text-align: center;
    padding: 40px 20px;
  }
  .form-success .success-icon { font-size: 56px; margin-bottom: 16px; }
  .form-success h3 { font-size: 22px; font-weight: 800; color: #1a4d2e; margin-bottom: 8px; }
  .form-success p { font-size: 15px; color: #555; line-height: 1.6; }

  /* CONTACT INFO */
  .contact-info { display: flex; flex-direction: column; gap: 24px; }

  .info-card {
    background: #f8fdf9;
    border-radius: 12px;
    padding: 24px;
    border-left: 4px solid #1a4d2e;
  }
  .info-card-header { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .info-icon {
    width: 42px; height: 42px;
    background: #1a4d2e;
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    flex-shrink: 0;
  }
  .info-card h3 { font-size: 15px; font-weight: 700; color: #1a4d2e; }
  .info-card p { font-size: 14px; color: #555; line-height: 1.7; }
  .info-card a { color: #1a4d2e; text-decoration: none; font-weight: 700; }
  .info-card a:hover { color: #f59e0b; }

  .emergency-card {
    background: linear-gradient(135deg, #1a4d2e, #2d6a4f);
    border-radius: 12px;
    padding: 28px;
    text-align: center;
  }
  .emergency-card h3 { font-size: 16px; font-weight: 700; color: rgba(255,255,255,0.85); margin-bottom: 8px; }
  .emergency-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #f59e0b;
    color: #1a1a1a;
    text-decoration: none;
    font-weight: 800;
    font-size: 20px;
    padding: 14px 24px;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .emergency-phone:hover { background: #d97706; }
  .emergency-note { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 10px; }

  /* MAP */
  .map-section { background: #f0f4f1; padding: 64px 0; }
  .map-section h2 { font-size: 28px; font-weight: 800; color: #1a4d2e; margin-bottom: 8px; }
  .map-section p { font-size: 15px; color: #555; margin-bottom: 28px; }
  .map-embed {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.12);
    height: 400px;
  }
  .map-embed iframe { width: 100%; height: 100%; border: 0; }

  /* TRUST BADGES */
  .trust-section { padding: 56px 0; background: #fff; }
  .trust-badges {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 40px;
  }
  .trust-badge {
    background: #f8fdf9;
    border: 2px solid #d4edda;
    border-radius: 12px;
    padding: 28px 20px;
    text-align: center;
    transition: all 0.2s;
  }
  .trust-badge:hover { border-color: #1a4d2e; background: #e8f5ee; transform: translateY(-3px); }
  .trust-badge .b-icon { font-size: 36px; display: block; margin-bottom: 12px; }
  .trust-badge h4 { font-size: 14px; font-weight: 700; color: #1a4d2e; margin-bottom: 4px; }
  .trust-badge p { font-size: 12px; color: #666; }

  /* Responsive */
  @media (max-width: 900px) {
    .contact-split { grid-template-columns: 1fr; gap: 40px; }
    .form-card { padding: 28px; }
    .form-row { grid-template-columns: 1fr; }
    .form-group.full { grid-column: span 1; }
    .trust-badges { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 600px) {
    .trust-badges { grid-template-columns: 1fr 1fr; gap: 12px; }
    .trust-badge { padding: 20px 14px; }
  }
</style>

<!-- PAGE HERO -->
<section class="page-hero">
  <div class="container page-hero-content">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span class="current">Contact</span>
    </div>
    <h1>Get Your <span>Free Estimate</span> Today</h1>
    <p>Ready to get started? Fill out the form below or give us a call. We'll come out, assess your trees, and give you an honest quote — free, fast, and no pressure.</p>
  </div>
</section>

<!-- CONTACT SECTION -->
<section class="contact-section">
  <div class="container">
    <div class="contact-split">

      <!-- FORM -->
      <div class="form-card">
        <h2>Request a Free Estimate</h2>
        <p class="form-sub">Fill out the form and we'll get back to you within 24 hours (usually much faster).</p>

        <form id="contact-form" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
          <input type="hidden" name="form-name" value="contact" />
          <p style="display:none;"><input name="bot-field" /></p>

          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name <span>*</span></label>
              <input type="text" id="name" name="name" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number <span>*</span></label>
              <input type="tel" id="phone" name="phone" placeholder="(469) 000-0000" required />
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" />
          </div>

          <div class="form-group">
            <label for="address">Property Address</label>
            <input type="text" id="address" name="address" placeholder="Street address (city, TX)" />
          </div>

          <div class="form-group">
            <label for="service">Service Needed <span>*</span></label>
            <select id="service" name="service" required>
              <option value="" disabled selected>Select a service...</option>
              <option value="tree-trimming">Tree Trimming &amp; Pruning</option>
              <option value="tree-removal">Tree Removal</option>
              <option value="stump-grinding">Stump Grinding</option>
              <option value="land-clearing">Land Clearing</option>
              <option value="emergency">Emergency Tree Service</option>
              <option value="tree-health">Tree Health &amp; Maintenance</option>
              <option value="multiple">Multiple Services</option>
              <option value="other">Other / Not Sure</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Tell Us More</label>
            <textarea id="message" name="message" placeholder="Describe your trees, the work you need done, any access concerns, or anything else that will help us give you an accurate estimate..."></textarea>
          </div>

          <button type="submit" class="form-submit">
            Request My Free Estimate →
          </button>
          <p class="form-disclaimer">By submitting, you agree to be contacted by Hodge Boys Tree Service regarding your request. We do not share your information with third parties.</p>
        </form>

        <div class="form-success" id="form-success">
          <div class="success-icon">✅</div>
          <h3>Request Received!</h3>
          <p>Thanks for reaching out! Dorrell will give you a call shortly. If it's urgent, call us directly at <a href="tel:4694372740" style="color:#1a4d2e; font-weight:700;">469-437-2740</a>.</p>
        </div>
      </div>

      <!-- CONTACT INFO -->
      <div class="contact-info">

        <div class="info-card">
          <div class="info-card-header">
            <div class="info-icon">📞</div>
            <h3>Phone</h3>
          </div>
          <p><a href="tel:4694372740">469-437-2740</a></p>
          <p style="font-size:12px; color:#888; margin-top:4px;">Call or text us anytime</p>
        </div>

        <div class="info-card">
          <div class="info-card-header">
            <div class="info-icon">📍</div>
            <h3>Service Area</h3>
          </div>
          <p>Forney, Crandall, Kemp, Waxahachie, Mesquite, Seagoville, Kaufman, Terrell, and surrounding DFW / East Texas communities.</p>
        </div>

        <div class="info-card">
          <div class="info-card-header">
            <div class="info-icon">🕐</div>
            <h3>Hours</h3>
          </div>
          <p>
            <strong>Monday – Saturday:</strong> 7:00 AM – 6:00 PM<br />
            <strong>Sunday:</strong> By appointment<br />
          </p>
          <p style="color: #1a4d2e; font-weight: 700; font-size: 13px; margin-top: 8px;">⚡ Emergency calls accepted 24/7</p>
        </div>

        <div class="info-card">
          <div class="info-card-header">
            <div class="info-icon">💬</div>
            <h3>What Happens Next?</h3>
          </div>
          <p>After you submit your request, Dorrell will personally review it and reach out within a few hours to schedule your free on-site estimate. Most estimates are scheduled within 1–2 days.</p>
        </div>

        <div class="emergency-card">
          <h3>🚨 Tree Emergency?</h3>
          <a href="tel:4694372740" class="emergency-phone">
            📞 Call Now: 469-437-2740
          </a>
          <p class="emergency-note">Available 24/7 for storm damage, fallen trees, and urgent situations</p>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- MAP -->
<section class="map-section">
  <div class="container">
    <h2>Serving Forney &amp; Surrounding Areas</h2>
    <p>Based out of Forney, TX — we cover the entire DFW Metroplex and East Texas region.</p>
    <div class="map-embed">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d107225.04986591028!2d-96.57098!3d32.74820!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x864e9e6e1a1b85c9%3A0x8dce96f7a3213ede!2sForney%2C%20TX!5e0!3m2!1sen!2sus!4v1700000000000!5m2!1sen!2sus"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Hodge Boys Tree Service - Forney TX Service Area"
      ></iframe>
    </div>
  </div>
</section>

<!-- TRUST BADGES -->
<section class="trust-section">
  <div class="container">
    <div style="text-align:center;">
      <div class="badge">Why Hire Us</div>
      <h2 class="section-title" style="text-align:center;">You're In Good Hands</h2>
      <p class="section-sub" style="margin:0 auto 0; text-align:center;">Every Hodge Boys job comes backed by our commitment to quality, safety, and your satisfaction.</p>
    </div>
    <div class="trust-badges">
      <div class="trust-badge">
        <span class="b-icon">🛡️</span>
        <h4>Fully Licensed</h4>
        <p>Properly licensed to operate in Texas</p>
      </div>
      <div class="trust-badge">
        <span class="b-icon">✅</span>
        <h4>Fully Insured</h4>
        <p>General liability &amp; workers' comp coverage</p>
      </div>
      <div class="trust-badge">
        <span class="b-icon">💬</span>
        <h4>Free Estimates</h4>
        <p>Honest quotes with no obligation</p>
      </div>
      <div class="trust-badge">
        <span class="b-icon">🏡</span>
        <h4>Local &amp; Family Owned</h4>
        <p>Serving our community since day one</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    try {
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as any).toString(),
      });

      form.style.display = 'none';
      if (successMsg) successMsg.style.display = 'block';
    } catch (_err) {
      // Fallback: still show success since this is static
      form.style.display = 'none';
      if (successMsg) successMsg.style.display = 'block';
    }
  });
</script>

</TreeLayout>
