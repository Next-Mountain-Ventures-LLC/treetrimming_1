---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Hodge Boys Tree Service | Forney, Crandall & Kemp TX",
  description = "Professional tree services in Forney, Crandall, Kemp, and the DFW area. Tree trimming, removal, stump grinding, land clearing & emergency services. Call 469-437-2740 for a free estimate.",
} = Astro.props;

const phone = "469-437-2740";
const phoneHref = "tel:4694372740";
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={base + "favicon.svg"} type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Poppins', sans-serif !important;
        background: #fff !important;
        background-color: #fff !important;
        color: #1a1a1a !important;
        background-image: none !important;
      }

      /* ===== NAV ===== */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: #fff;
        box-shadow: 0 2px 20px rgba(0,0,0,0.10);
      }
      .nav-wrap {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 72px;
      }
      .nav-logo { text-decoration: none; display: flex; align-items: center; gap: 10px; }
      .nav-logo-icon {
        width: 42px; height: 42px;
        background: #1a4d2e;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
      }
      .nav-logo-text { display: flex; flex-direction: column; line-height: 1.1; }
      .nav-logo-name {
        font-size: 16px;
        font-weight: 800;
        color: #1a4d2e;
        letter-spacing: -0.3px;
      }
      .nav-logo-sub {
        font-size: 10px;
        font-weight: 500;
        color: #555;
        letter-spacing: 0.5px;
        text-transform: uppercase;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 32px;
        list-style: none;
      }
      .nav-links a {
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        color: #333;
        transition: color 0.2s;
        letter-spacing: 0.2px;
      }
      .nav-links a:hover { color: #1a4d2e; }
      .nav-cta {
        background: #f59e0b;
        color: #1a1a1a !important;
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 700 !important;
        font-size: 13px !important;
        text-decoration: none;
        transition: background 0.2s, transform 0.1s !important;
        white-space: nowrap;
        display: flex; align-items: center; gap: 6px;
      }
      .nav-cta:hover { background: #d97706 !important; transform: translateY(-1px); }
      .nav-phone {
        color: #1a4d2e !important;
        font-weight: 700 !important;
        font-size: 14px !important;
        text-decoration: none;
        display: flex; align-items: center; gap: 5px;
      }
      .nav-phone:hover { color: #2d6a4f !important; }

      /* ===== MOBILE NAV ===== */
      .hamburger {
        display: none;
        flex-direction: column;
        gap: 5px;
        cursor: pointer;
        background: none;
        border: none;
        padding: 6px;
      }
      .hamburger span {
        display: block;
        width: 24px; height: 2px;
        background: #1a4d2e;
        border-radius: 2px;
        transition: all 0.3s;
      }
      .mobile-nav {
        display: none;
        position: fixed;
        top: 72px; left: 0; right: 0; bottom: 0;
        background: #fff;
        z-index: 99;
        padding: 24px;
        flex-direction: column;
        gap: 0;
        overflow-y: auto;
      }
      .mobile-nav.open { display: flex; }
      .mobile-nav a {
        text-decoration: none;
        font-size: 18px;
        font-weight: 600;
        color: #333;
        padding: 16px 0;
        border-bottom: 1px solid #eee;
        display: block;
        transition: color 0.2s;
      }
      .mobile-nav a:hover { color: #1a4d2e; }
      .mobile-nav .mobile-cta {
        margin-top: 24px;
        background: #f59e0b;
        color: #1a1a1a;
        text-align: center;
        border-radius: 8px;
        padding: 16px;
        font-size: 17px;
        font-weight: 700;
        border-bottom: none;
      }
      .mobile-nav .mobile-phone {
        margin-top: 12px;
        background: #1a4d2e;
        color: #fff;
        text-align: center;
        border-radius: 8px;
        padding: 16px;
        font-size: 17px;
        font-weight: 700;
        border-bottom: none;
      }

      /* ===== FOOTER ===== */
      .site-footer { background: #0f2419; color: #fff; }
      .footer-top {
        max-width: 1280px;
        margin: 0 auto;
        padding: 64px 24px 48px;
        display: grid;
        grid-template-columns: 1.5fr 1fr 1fr 1fr;
        gap: 48px;
      }
      .footer-brand-name {
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        margin-bottom: 4px;
      }
      .footer-brand-tag {
        font-size: 11px;
        color: #52b788;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 16px;
      }
      .footer-desc {
        font-size: 13px;
        color: #aaa;
        line-height: 1.7;
        margin-bottom: 20px;
      }
      .footer-phone-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f59e0b;
        color: #1a1a1a;
        text-decoration: none;
        font-weight: 700;
        font-size: 16px;
        padding: 12px 20px;
        border-radius: 6px;
        transition: background 0.2s;
      }
      .footer-phone-link:hover { background: #d97706; }
      .footer-col h4 {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #52b788;
        margin-bottom: 20px;
      }
      .footer-col ul { list-style: none; }
      .footer-col ul li { margin-bottom: 10px; }
      .footer-col ul li a {
        color: #bbb;
        text-decoration: none;
        font-size: 14px;
        transition: color 0.2s;
      }
      .footer-col ul li a:hover { color: #fff; }
      .footer-col p { color: #bbb; font-size: 13px; line-height: 1.7; }
      .footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.08);
        padding: 20px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        max-width: 1280px;
        margin: 0 auto;
        font-size: 13px;
        color: #666;
      }
      .footer-bottom a { color: #888; text-decoration: none; transition: color 0.2s; }
      .footer-bottom a:hover { color: #fff; }

      /* ===== SHARED UTILITIES ===== */
      .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
      .section { padding: 80px 0; }
      .section-sm { padding: 48px 0; }
      .section-title {
        font-size: clamp(28px, 4vw, 42px);
        font-weight: 800;
        color: #1a4d2e;
        margin-bottom: 8px;
        line-height: 1.15;
      }
      .section-sub {
        font-size: 17px;
        color: #555;
        max-width: 600px;
        line-height: 1.6;
      }
      .badge {
        display: inline-block;
        background: #e8f5ee;
        color: #1a4d2e;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 5px 14px;
        border-radius: 100px;
        margin-bottom: 14px;
      }
      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #f59e0b;
        color: #1a1a1a;
        text-decoration: none;
        font-weight: 700;
        font-size: 15px;
        padding: 14px 28px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        font-family: 'Poppins', sans-serif;
      }
      .btn-primary:hover { background: #d97706; transform: translateY(-1px); }
      .btn-secondary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #1a4d2e;
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 15px;
        padding: 14px 28px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        font-family: 'Poppins', sans-serif;
      }
      .btn-secondary:hover { background: #2d6a4f; transform: translateY(-1px); }
      .btn-outline {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        color: #fff;
        text-decoration: none;
        font-weight: 700;
        font-size: 15px;
        padding: 13px 28px;
        border-radius: 6px;
        border: 2px solid #fff;
        cursor: pointer;
        transition: all 0.2s;
        font-family: 'Poppins', sans-serif;
      }
      .btn-outline:hover { background: #fff; color: #1a4d2e; }

      /* Card hover effect */
      .card-hover {
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .card-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 48px rgba(0,0,0,0.12) !important;
      }

      /* Responsive */
      @media (max-width: 900px) {
        .nav-links { display: none; }
        .hamburger { display: flex; }
        .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
        .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
      }
      @media (max-width: 600px) {
        .footer-top { grid-template-columns: 1fr; }
        .nav-wrap { height: 64px; }
        .section { padding: 56px 0; }
      }

      /* ===== POPUP MODAL ===== */
      .popup-overlay {
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5);
        z-index: 999;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        backdrop-filter: blur(2px);
      }
      .popup-overlay.show { display: flex; animation: fadeInOverlay 0.3s ease-out; }
      @keyframes fadeInOverlay { from { opacity: 0; } to { opacity: 1; } }

      .popup-modal {
        position: relative;
        background: #fff;
        border-radius: 16px;
        padding: 40px;
        max-width: 460px;
        width: 100%;
        box-shadow: 0 20px 80px rgba(0,0,0,0.25);
        animation: slideInModal 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      }
      @keyframes slideInModal {
        from { transform: translateY(-40px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
      }

      .popup-close {
        position: absolute;
        top: 16px; right: 16px;
        width: 32px; height: 32px;
        border: none;
        background: #f0f0f0;
        border-radius: 50%;
        cursor: pointer;
        font-size: 18px;
        color: #666;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.2s;
      }
      .popup-close:hover { background: #1a4d2e; color: #fff; }

      .popup-icon {
        font-size: 48px;
        text-align: center;
        margin-bottom: 16px;
      }

      .popup-title {
        font-size: 28px;
        font-weight: 800;
        color: #1a4d2e;
        text-align: center;
        margin-bottom: 12px;
        line-height: 1.2;
      }

      .popup-text {
        font-size: 15px;
        color: #555;
        text-align: center;
        line-height: 1.7;
        margin-bottom: 24px;
      }
      .popup-text strong { color: #f59e0b; font-weight: 700; }

      .popup-btn-primary {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        width: 100%;
        background: #f59e0b;
        color: #1a1a1a;
        text-decoration: none;
        font-weight: 700;
        font-size: 16px;
        padding: 16px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        font-family: 'Poppins', sans-serif;
        margin-bottom: 24px;
      }
      .popup-btn-primary:hover { background: #d97706; transform: translateY(-2px); }

      .popup-btn-secondary {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        background: transparent;
        color: #666;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        padding: 12px;
        border: none;
        cursor: pointer;
        transition: color 0.2s;
        font-family: 'Poppins', sans-serif;
        margin-bottom: 24px;
      }
      .popup-btn-secondary:hover { color: #1a4d2e; }

      .popup-timer {
        background: #f8fdf9;
        border: 2px solid #d4edda;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
      }

      #timer-display {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        margin-bottom: 16px;
      }

      .timer-unit {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
      }

      .timer-value {
        font-size: 32px;
        font-weight: 900;
        color: #1a4d2e;
        line-height: 1;
        min-width: 36px;
        text-align: center;
      }

      .timer-label {
        font-size: 11px;
        font-weight: 700;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .timer-separator {
        font-size: 20px;
        font-weight: 900;
        color: #1a4d2e;
        margin: 0 2px;
      }

      .timer-message {
        font-size: 12px;
        color: #888;
        line-height: 1.5;
        margin: 0;
      }

      @media (max-width: 600px) {
        .popup-modal { padding: 32px 24px; max-width: 100%; }
        .popup-title { font-size: 24px; }
        .popup-text { font-size: 14px; }
        .days-remaining { font-size: 40px; }
      }
    </style>
  </head>
  <body>
    <!-- HEADER -->
    <header class="site-header">
      <div class="nav-wrap">
        <a href={base} class="nav-logo">
          <div class="nav-logo-icon">🌲</div>
          <div class="nav-logo-text">
            <span class="nav-logo-name">Hodge Boys</span>
            <span class="nav-logo-sub">Tree Service</span>
          </div>
        </a>

        <nav>
          <ul class="nav-links">
            <li><a href={base}>Home</a></li>
            <li><a href={base + "services"}>Services</a></li>
            <li><a href={base + "about"}>About Us</a></li>
            <li><a href={base + "contact"}>Contact</a></li>
            <li>
              <a href={phoneHref} class="nav-phone">
                📞 {phone}
              </a>
            </li>
            <li>
              <a href={base + "contact"} class="nav-cta">
                Free Estimate
              </a>
            </li>
          </ul>
        </nav>

        <button class="hamburger" id="hamburger-btn" aria-label="Open menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <!-- MOBILE NAV -->
    <div class="mobile-nav" id="mobile-nav">
      <a href={base} onclick="closeMobileNav()">Home</a>
      <a href={base + "services"} onclick="closeMobileNav()">Services</a>
      <a href={base + "about"} onclick="closeMobileNav()">About Us</a>
      <a href={base + "contact"} onclick="closeMobileNav()">Contact</a>
      <a href={phoneHref} class="mobile-phone">📞 Call {phone}</a>
      <a href={base + "contact"} class="mobile-cta">Get a Free Estimate →</a>
    </div>

    <!-- POPUP MODAL -->
    <div class="popup-overlay" id="popup-overlay">
      <div class="popup-modal">
        <button class="popup-close" id="popup-close" aria-label="Close popup">✕</button>

        <div class="popup-content">
          <div class="popup-icon">🌲</div>
          <h2 class="popup-title">Own This Website</h2>
          <p class="popup-text">
            Buy this website for <strong>$49 per month</strong> and book a meeting with your designer to adjust things to your specification.
          </p>

          <a href="https://buy.stripe.com/eVq6oI1vu5VEc7LbmogMw0c" class="popup-btn-primary" target="_blank" rel="noopener noreferrer">
            Buy Now →
          </a>

          <button class="popup-btn-secondary" id="popup-no-thanks">
            No thanks
          </button>

          <div class="popup-timer">
            <div class="timer-display" id="timer-display">
              <span class="timer-unit"><span class="timer-value" id="timer-days">7</span><span class="timer-label">d</span></span>
              <span class="timer-separator">:</span>
              <span class="timer-unit"><span class="timer-value" id="timer-hours">00</span><span class="timer-label">h</span></span>
              <span class="timer-separator">:</span>
              <span class="timer-unit"><span class="timer-value" id="timer-minutes">00</span><span class="timer-label">m</span></span>
              <span class="timer-separator">:</span>
              <span class="timer-unit"><span class="timer-value" id="timer-seconds">00</span><span class="timer-label">s</span></span>
            </div>
            <p class="timer-message">This website will delete itself and expire if not claimed within 7 days.</p>
          </div>
        </div>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-top">
        <div>
          <div class="footer-brand-name">🌲 Hodge Boys Tree Service</div>
          <div class="footer-brand-tag">Forney • Crandall • Kemp • DFW</div>
          <p class="footer-desc">
            Locally owned and operated by Dorrell Hodge. Serving the Forney, 
            Crandall, Kemp, Waxahachie, Mesquite, and greater DFW area with 
            professional, reliable tree care.
          </p>
          <a href={phoneHref} class="footer-phone-link">
            📞 {phone}
          </a>
        </div>

        <div class="footer-col">
          <h4>Services</h4>
          <ul>
            <li><a href={base + "services"}>Tree Trimming</a></li>
            <li><a href={base + "services"}>Tree Removal</a></li>
            <li><a href={base + "services"}>Stump Grinding</a></li>
            <li><a href={base + "services"}>Land Clearing</a></li>
            <li><a href={base + "services"}>Emergency Service</a></li>
            <li><a href={base + "services"}>Tree Health</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Company</h4>
          <ul>
            <li><a href={base}>Home</a></li>
            <li><a href={base + "about"}>About Us</a></li>
            <li><a href={base + "contact"}>Contact</a></li>
            <li><a href={base + "contact"}>Free Estimate</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4>Service Area</h4>
          <p>
            Forney, TX<br />
            Crandall, TX<br />
            Kemp, TX<br />
            Waxahachie, TX<br />
            Mesquite, TX<br />
            Seagoville, TX<br />
            Kaufman, TX<br />
            Terrell, TX<br />
            &amp; surrounding DFW areas
          </p>
        </div>
      </div>

      <div class="footer-bottom container">
        <span>© {new Date().getFullYear()} Hodge Boys Tree Service. All rights reserved.</span>
        <span>Licensed &amp; Insured | Forney, TX</span>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('hamburger-btn');
      const nav = document.getElementById('mobile-nav');

      function closeMobileNav() {
        nav?.classList.remove('open');
      }

      btn?.addEventListener('click', () => {
        nav?.classList.toggle('open');
      });

      // Close on outside click
      document.addEventListener('click', (e) => {
        if (nav?.classList.contains('open') && !nav.contains(e.target as Node) && e.target !== btn && !btn?.contains(e.target as Node)) {
          nav.classList.remove('open');
        }
      });

      // Popup modal logic
      const popupOverlay = document.getElementById('popup-overlay');
      const popupClose = document.getElementById('popup-close');
      const popupNoThanks = document.getElementById('popup-no-thanks');
      const timerDays = document.getElementById('timer-days');
      const timerHours = document.getElementById('timer-hours');
      const timerMinutes = document.getElementById('timer-minutes');
      const timerSeconds = document.getElementById('timer-seconds');

      // Close popup helper
      function closePopup() {
        if (popupOverlay) popupOverlay.classList.remove('show');
      }

      // Calculate and update 7-day countdown (days:hours:minutes:seconds)
      function startCountdown() {
        const now = new Date();
        const expiryTime = new Date(now.getTime() + 7 * 24 * 60 * 60 * 1000);

        // Update every second
        const interval = setInterval(() => {
          const currentTime = new Date();
          const timeLeft = expiryTime.getTime() - currentTime.getTime();

          if (timeLeft <= 0) {
            if (timerDays) timerDays.textContent = '0';
            if (timerHours) timerHours.textContent = '00';
            if (timerMinutes) timerMinutes.textContent = '00';
            if (timerSeconds) timerSeconds.textContent = '00';
            clearInterval(interval);
          } else {
            const totalSeconds = Math.floor(timeLeft / 1000);
            const days = Math.floor(totalSeconds / (24 * 60 * 60));
            const hours = Math.floor((totalSeconds % (24 * 60 * 60)) / (60 * 60));
            const minutes = Math.floor((totalSeconds % (60 * 60)) / 60);
            const seconds = totalSeconds % 60;

            if (timerDays) timerDays.textContent = String(days);
            if (timerHours) timerHours.textContent = String(hours).padStart(2, '0');
            if (timerMinutes) timerMinutes.textContent = String(minutes).padStart(2, '0');
            if (timerSeconds) timerSeconds.textContent = String(seconds).padStart(2, '0');
          }
        }, 1000);
      }

      // Show popup after 10 seconds
      setTimeout(() => {
        if (popupOverlay) {
          popupOverlay.classList.add('show');
          startCountdown();
        }
      }, 10000);

      // Close popup on close button
      popupClose?.addEventListener('click', closePopup);

      // Close popup on "No thanks" button
      popupNoThanks?.addEventListener('click', closePopup);

      // Close popup on overlay click (outside modal)
      popupOverlay?.addEventListener('click', (e) => {
        if (e.target === popupOverlay) {
          closePopup();
        }
      });
    </script>
  </body>
</html>
