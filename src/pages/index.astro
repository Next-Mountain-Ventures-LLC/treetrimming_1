          <a href="/services" class="service-link">Learn More →</a>
        </div>
      </div>

      <div class="service-card">
        <div class="service-card-img">
          <img src="https://images.pexels.com/photos/7812853/pexels-photo-7812853.jpeg?auto=compress&cs=tinysrgb&w=600" alt="Tree Health Service" loading="lazy" />
