# ================================================
# WORDPRESS_SETUP.md - Required for all sites
# ================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env (in the repository root)
# 2. Update the values for YOUR site below
# 3. COMMIT .env to GitHub (it's not gitignored)
# 4. Both local dev and GitHub Actions automatically use .env
#
# ================================================

# Site Configuration
# Your site's domain URL
SITE_URL=https://yoursite.com

# WordPress API Configuration
# The base URL of your WordPress REST API endpoint
# All sites use the same central WordPress instance
# Do NOT change this value
WORDPRESS_API_URL=https://blog.nxtmt.ventures/wp-json/wp/v2

# WordPress Category Slug
# Only posts from this category will be displayed on the blog
#
# ⚠️ IMPORTANT:
# - This .env file is read by BOTH local dev and GitHub Actions builds
# - When you commit .env to GitHub, GitHub Actions automatically uses it
# - You do NOT need to set GitHub repository secrets
# - Just keep this file committed with your site's category slug
#
# Find your category slug:
#   1. Go to WordPress admin: blog.nxtmt.ventures/wp-admin/
#   2. Click Posts → Categories
#   3. Find your category and copy the slug
#   4. Paste it below
#
# Examples: astrobot-design, thefordamily, spirituality
WORDPRESS_CATEGORY_SLUG=astrobot-design
